<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <packageSources>
        <clear />
        <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
        <!--
          Feed locale popolato da `dotnet pack tools/Contoso.SqlCodeAnalysis.Rules
          -c Release -o artifacts/local-nuget`. Necessario perché il .sqlproj
          referenzia Contoso.SqlCodeAnalysis.Rules via PackageReference e quel
          pacchetto non è pubblicato su nuget.org.
        -->
        <add key="local-nuget" value="./artifacts/local-nuget" />
    </packageSources>
</configuration>
